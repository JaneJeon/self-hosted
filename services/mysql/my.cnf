# https://dev.mysql.com/doc/refman/8.0/en/server-system-variables.html
# https://dev.mysql.com/doc/refman/8.0/en/innodb-parameters.html

[mysqld]
performance_schema = off # see README for memory breakdown and diagnosis
innodb_buffer_pool_size = 20M
max_connections = 20

innodb_redo_log_capacity = 67108864 # 64MB; 10MB caused excessive checkpoint pressure
skip-log-bin # no replication or PITR configured; binlogs are pure waste
innodb_default_row_format = DYNAMIC # prevent row-size errors with Uptime Kuma v2 schema

# MySQL 8.0.12+ raised the default to 64MB; at ~0.1 writes/s this is pure waste
innodb_log_buffer_size = 8M

# key_buffer_size is for MyISAM only; Ghost and Uptime Kuma are InnoDB-only, and MySQL 8
# converted all system tables to InnoDB — Key_blocks_used confirmed 0 on live instance
key_buffer_size = 8K

# Default is 4000 (doubled from 5.7); live instance shows Table_open_cache_overflows = 0
# and Open_tables peaks at ~1432, so halving is safe with zero performance impact
table_open_cache = 2000
